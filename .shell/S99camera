#!/bin/sh
#
# Start Camera
#

set -x

source /opt/config/mod/.shell/0.sh

if ! [ -f /opt/config/mod_data/camera.conf ]; then
    /opt/config/mod/.shell/zcamera.sh off 640 480 20 ${VIDEO} 0 NOTRESTART
fi

FS=0
source /opt/config/mod_data/camera.conf
PID_FILE=/run/camera.pid

up() {
    ${V4l2} --all
    ls -1 /dev/video? | while read a; do
        ${V4l2} -d $a --list-formats
        ${V4l2} -d $a --list-formats-ext
    done;

    >/opt/config/mod_data/log/cam.log
    if [ $START != "on" ]; then
        [ ${ZLANG} != 'ru' ] && echo "Camera off" >>/opt/config/mod_data/log/cam.log || echo "Камера отключена" >>/opt/config/mod_data/log/cam.log
        return 0
    fi

    if [ -c /dev/$VIDEO ]; then
        ${V4l2} -d /dev/$VIDEO --list-formats
        ${V4l2} -d /dev/$VIDEO --list-formats-ext
        if ${V4l2} -d /dev/$VIDEO  --list-formats | grep MJPG; then
            if [ "$FS" -ne "0" ]; then
                FFS="-fs $(( ${WIDTH} * ${HEIGHT} * 2 ))"
            else
                FFS=""
            fi
            ${V4l2} -d /dev/$VIDEO --set-fmt-video=width=${WIDTH},height=${HEIGHT},pixelformat=MJPG
            if [ -f /ZMOD ]; then
                start-stop-daemon -S -b -m -p $PID_FILE --exec /usr/bin/mjpg_streamer -- -o "/usr/lib/mjpg-streamer/output_http.so -w /usr/share/mjpg-streamer/www -p 8080" -i  "/usr/lib/mjpg-streamer/input_uvc.so -b 1 -d /dev/${VIDEO} -r ${WIDTH}x${HEIGHT} -f $FPS $FFS"
            else
                if [ ${FF5X} -eq 0 ]; then
                    start-stop-daemon -S -b -m -p $PID_FILE --exec /opt/config/mod/.shell/eabi/mjpg_streamer -- -o "/opt/config/mod/.shell/eabi/lib/output_http.so -w /opt/mjpg-streamer/www -p 8080" -i  "/opt/config/mod/.shell/eabi/lib/input_uvc.so -b 1 -d /dev/${VIDEO} -r ${WIDTH}x${HEIGHT} -f $FPS $FFS"
                else
                    chroot $MOD start-stop-daemon -S -b -m -p $PID_FILE --exec /usr/bin/mjpg_streamer -- -o "/usr/lib/mjpg-streamer/output_http.so -w /usr/share/mjpg-streamer/www -p 8080" -i  "/usr/lib/mjpg-streamer/input_uvc.so -b 1 -d /dev/${VIDEO} -r ${WIDTH}x${HEIGHT} -f $FPS $FFS"
                fi
            fi
        else
            FORMAT=$(${V4l2} -d /dev/$VIDEO --list-formats| grep '\[' | tail -1| cut -d "'" -f2)
            if [ -f /ZMOD ]; then
                start-stop-daemon -S -b -m -p $PID_FILE --exec /bin/ustreamer -- -d /dev/${VIDEO} -r ${WIDTH}x${HEIGHT} -f $FPS --format=$FORMAT -s 0.0.0.0
            else
                [ ${FF5X} -eq 0 ] && [ "$1" != "init" ] && umount ${UMOUNT_MOD}
                chroot ${MOD} start-stop-daemon -S -b -m -p $PID_FILE --exec /bin/ustreamer -- -d /dev/${VIDEO} -r ${WIDTH}x${HEIGHT} -f $FPS --format=$FORMAT -s 0.0.0.0
                [ ${FF5X} -eq 0 ] && [ "$1" != "init" ] && mount --bind ${REMOUNT_MOD} ${UMOUNT_MOD}
            fi
        fi
        [ ${ZLANG} != 'ru' ] && echo "Camera started" >>/opt/config/mod_data/log/cam.log || echo "Запуск камеры завершен" >>/opt/config/mod_data/log/cam.log
    else
        [ ${ZLANG} != 'ru' ] && echo "Camera not found $VIDEO" >>/opt/config/mod_data/log/cam.log || echo "Камера не существует $VIDEO" >>/opt/config/mod_data/log/cam.log
        cd /dev/
        ls -1 video? | while read a; do
            if ${V4l2} -d /dev/$a --list-formats-ext 2>/dev/null |grep MJPG >/dev/null 2>/dev/null; then
                echo "Test: CAMERA_ON VIDEO=$a" >>/opt/config/mod_data/log/cam.log
            fi
        done
    fi
}

stop() {
    start-stop-daemon -K -p $PID_FILE 2>/dev/null >/dev/null
    killall mjpg_streamer ustreamer
}
restart() {
    stop
    sleep 2
    up &>/opt/config/mod_data/log/camera.log
}

case "$1" in
  start)
        ;;
  up|init)
        up $1 &>/opt/config/mod_data/log/camera.log
        ;;
  stop)
        stop
        ;;
  restart|reload)
        restart
        ;;
  *)
        echo "Usage: $0 {init|up|stop|restart}"
        exit 1
esac

exit $?
